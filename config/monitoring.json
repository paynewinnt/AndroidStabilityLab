{
  "monitoring": {
    "backend": "adb_collector",
    "fallback_backend": "adb_collector",
    "sample_interval": 2,
    "duration_minutes": 20,
    "max_apps": 6,
    "auto_start": false,
    "solox": {
      "surfaceview": true,
      "network_wifi": true,
      "no_log": true,
      "record": false,
      "enabled_metrics": [
        "cpu",
        "memory",
        "memory_detail",
        "network",
        "fps",
        "battery",
        "gpu"
      ]
    }
  },
  "thresholds": {
    "cpu_max": 90,
    "memory_max": 80,
    "network_max": 1000,
    "fps_min": 30
  },
  "presets": [
    {
      "name": "Default",
      "packages": [],
      "sample_interval": 1,
      "duration_minutes": 20
    },
    {
      "name": "Performance Test",
      "packages": [],
      "sample_interval": 1,
      "duration_minutes": 30
    },
    {
      "name": "Long Term",
      "packages": [],
      "sample_interval": 5,
      "duration_minutes": 240
    }
  ],
  "adb": {
    "timeout": 10,
    "retry_count": 3,
    "commands": {
      "list_packages": "shell pm list packages -3",
      "cpu_info": "shell dumpsys cpuinfo",
      "mem_info": "shell dumpsys meminfo",
      "battery_stats": "shell dumpsys batterystats",
      "network_stats": "shell cat /proc/net/xt_qtaguid/stats"
    }
  },
  "integration_backends": {
    "default_profile": "adb",
    "profiles": {
      "adb": {
        "metrics_backend": "adb_collector",
        "trace_backend": "",
        "metadata": {}
      },
      "perfetto": {
        "metrics_backend": "adb_collector",
        "trace_backend": "perfetto",
        "metadata": {
          "perfetto_buffer_size_kb": 32768,
          "perfetto_remote_path_template": "/data/local/tmp/{session_name}.perfetto-trace",
          "perfetto_enable_network_packets": false
        }
      },
      "solox": {
        "metrics_backend": "solox",
        "trace_backend": "",
        "metadata": {
          "solox_surfaceview": true,
          "solox_wifi": true
        }
      },
      "solox_perfetto": {
        "metrics_backend": "solox",
        "trace_backend": "perfetto",
        "metadata": {
          "solox_surfaceview": true,
          "solox_wifi": true,
          "perfetto_buffer_size_kb": 32768,
          "perfetto_remote_path_template": "/data/local/tmp/{session_name}.perfetto-trace",
          "perfetto_enable_network_packets": false
        }
      }
    }
  }
}
